	quests: [
		{
			description: [
				"Breeding is Cobblemon's deepest system — a way to create Cobblemon that are better than anything you'd find in the wild."
				""
				"To breed, leave two compatible Cobblemon together. Compatible means they share an egg group — check the Cobblepedia for each species' egg group. Given time, they'll produce an egg."
				""
				"The egg group system is broad. Many seemingly unrelated species share egg groups, opening up unexpected breeding combinations."
				""
				"&7Tip: Cobblemon in the same egg group will produce an egg together over time — check Cobblepedia.&r"
			]
			icon: "cobblemon:oval_stone"
			id: "10000000000000C8"
			min_width: 320
			rewards: [
