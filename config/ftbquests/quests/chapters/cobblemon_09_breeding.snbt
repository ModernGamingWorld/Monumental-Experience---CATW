		{
			dependencies: ["10000000000000CF"]
			description: [
				"&eEgg moves&r are moves a Cobblemon can only learn through breeding — not by levelling up, not from TMs, not from any other source."
				""
				"The father passes egg moves to the offspring, so you need a compatible male that knows the desired move. This sometimes requires a breeding chain — breeding with an intermediate species first to pass the move across egg groups."
				""
				"Egg moves can dramatically change a Cobblemon's capabilities, opening strategies unavailable through normal training."
				""
				"&7Tip: Egg moves are inherited from the father — plan your breeding chain carefully.&r"
			]
			id: "10000000000000D5"
			min_width: 340
			rewards: [{
				count: 2
				id: "10000000000000D4"
				item: "cobblemon:pp_max"
				type: "item"
			}]
