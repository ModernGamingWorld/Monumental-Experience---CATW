					item: "cobblemon:water_stone"
					type: "item"
				}
			]
			shape: "square"
			subtitle: "Beneath the Waves"
			tasks: [{
				id: "100000000000004B"
				title: "Catch a Water-type Cobblemon in an ocean biome"
				type: "checkmark"
			}]
			title: "&bOcean Diver"
			x: 4.0d
			y: 0.0d
		}
		{
			dependencies: ["100000000000004E"]
			description: [
				"Underground spawns are a different world entirely. Rock, Ground, and Dark types lurk in caves and the deep slate layer, away from the light."
				""
				"&eDusk Balls&r are most effective in dark areas — underground during the day, or anywhere at night. They're your best tool for cave hunting and worth keeping stocked."
				""
				"The deeper you go, the rarer and stronger the Cobblemon. Don't go caving underprepared — bring healing items and a strong team."
				""
				"&7Tip: Dusk Balls are most effective underground or at night — time your trips.&r"
			]
			id: "1000000000000052"
			min_width: 320
			rewards: [
				{
					count: 5
