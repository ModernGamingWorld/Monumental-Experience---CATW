	quests: [
		{
			description: [
				"Forests are one of the most Cobblemon-dense biomes in the game. Bug, Grass, and Normal types fill the canopy and undergrowth, and the modded forest variants added by Terralith bring even more unique spawns."
				""
				"Each sub-type of forest — dark forest, birch forest, old growth taiga — has different Cobblemon populations. Don't just visit one and move on."
				""
				"Net Balls are particularly effective against Bug and Water types, making them ideal for forest hunting."
				""
				"&7Tip: Explore all forest variants — each sub-biome has different spawns.&r"
			]
			icon: "cobblemon:net_ball"
			id: "1000000000000046"
			min_width: 320
			rewards: [
				{
					count: 5
