					item: "cobblemon:leaf_stone"
					type: "item"
				}
			]
			shape: "square"
			subtitle: "Into the Woods"
			tasks: [{
				id: "1000000000000043"
				title: "Catch a forest-exclusive Cobblemon"
				type: "checkmark"
			}]
			title: "&bForest Finder"
			x: 0.0d
			y: 0.0d
		}
		{
			description: [
				"Desert and badlands biomes are home to Fire and Ground types that thrive in the heat. These Cobblemon tend to be tougher than forest species — good hunting for a trainer who's been levelling up."
				""
				"Badlands count as desert-adjacent for spawn purposes, so both biomes are worth visiting. You'll find different species in each despite the similar climate."
				""
				"Fire stones drop more commonly in these biomes too — worth picking up if you need them for any evolutions."
				""
				"&7Tip: Badlands count as desert-adjacent — check both biome types for different species.&r"
			]
			icon: "cobblemon:fire_stone"
			id: "100000000000004A"
			min_width: 320
			rewards: [
				{
					count: 5
					id: "1000000000000048"
					item: "cobblemon:net_ball"
					type: "item"
				}
				{
					id: "1000000000000049"
					item: "cobblemon:fire_stone"
					type: "item"
				}
			]
			shape: "square"
			subtitle: "Heat and Sand"
			tasks: [{
				id: "1000000000000047"
				title: "Catch a Cobblemon in a desert or badlands biome"
				type: "checkmark"
			}]
			title: "&bDesert Wanderer"
			x: 2.0d
			y: 0.0d
		}
		{
			description: [
				"The ocean is one of the largest biomes in the game and home to a wide variety of Water-type Cobblemon. Warm and cold oceans have different populations, as do ocean floors versus the surface."
				""
				"&eDive Balls&r are most effective against Water-type Cobblemon and even more so when used in water biomes. Craft a stack before you head out."
				""
				"Some rare Water-types only appear at specific ocean depths or in specific ocean variants — exploring thoroughly rewards you with species you can't find anywhere else."
				""
				"&7Tip: Dive Balls are most effective in water biomes — craft them before hunting.&r"
			]
			icon: "cobblemon:dive_ball"
			id: "100000000000004E"
			min_width: 330
			rewards: [
				{
