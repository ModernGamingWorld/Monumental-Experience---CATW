	quests: [
		{
			description: [
				"Cobblemon berries are more than held items — they're a farming system. Plant berry seeds in the ground, tend them over time, and harvest a steady supply of battle-ready consumables."
				""
				"Different berries prefer different conditions. Some grow faster in specific biomes, others need more light or wetter soil. Experiment with where you plant them."
				""
				"Start with five different types. &eOran&r and &eSitrus&r berries are essential early on — they restore HP mid-battle and are worth having stocked at all times."
				""
				"&7Tip: Experiment with planting in different biomes for best growth rates.&r"
			]
			icon: "cobblemon:oran_berry"
			id: "100000000000007A"
			min_width: 320
