		{
			dependencies: ["1000000000000009"]
			description: [
				"Your first real battle. Send your Cobblemon out and fight."
				""
				"Type matchups matter from the start — a Water-type move against a Fire-type deals extra damage, and vice versa. Pay attention to the type icons before selecting your move."
				""
				"Winning wild battles earns your Cobblemon experience points and helps them level up. Build good habits early — rotate your party and keep your team healthy."
				""
				"&7Tip: Check the Cobblepedia for type weaknesses before engaging a new species.&r"
			]
			id: "1000000000000010"
			min_width: 320
