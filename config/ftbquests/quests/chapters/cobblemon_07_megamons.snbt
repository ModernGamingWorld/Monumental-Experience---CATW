		}
		{
			dependencies: ["10000000000000A6"]
			description: [
				"You don't need to win. You just need to survive five turns."
				""
				"Megamons hit significantly harder than regular wild Cobblemon. Their moves are stronger, their stats are higher, and they won't hold back. Bring a full team, full healing items, and accept that you might lose members."
				""
				"Five turns is enough to understand what you're dealing with. Take notes. Come back stronger."
				""
				"&7Tip: Megamons hit much harder than wild Cobblemon — bring full healing and a well-levelled team.&r"
			]
			id: "10000000000000A9"
			min_width: 330
			rewards: [{
				count: 3
				id: "10000000000000A8"
				item: "cobblemon:max_revive"
				type: "item"
			}]
			shape: "square"
			subtitle: "Bravery or Recklessness?"
			tasks: [{
