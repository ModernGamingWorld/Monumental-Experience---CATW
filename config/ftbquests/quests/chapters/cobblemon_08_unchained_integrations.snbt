		}
		{
			description: [
				"&eCobblemon Integrations&r creates bridges between Cobblemon and other mods in the pack. Where normally these systems would operate in parallel, Integrations makes them interact."
				""
				"Depending on what's configured in this pack, you might find:"
				"• Cobblemon participating in Apotheosis encounters"
				"• Type affinities affecting drop tables from other mods"
				"• Cobblemon items functioning as ingredients in cross-mod recipes"
				""
				"Explore and experiment. The integration features are discovered by playing, not by reading."
				""
				"&7Tip: Cobblemon Integrations may bridge with Apotheosis, Gateways, and other pack mods.&r"
			]
			id: "10000000000000BE"
			min_width: 360
			rewards: [{
				count: 2
				id: "10000000000000BD"
				item: "cobblemon:rare_candy"
				type: "item"
			}]
